# OmniExtract Gateway — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── API Core ──────────────────────────────────────────────────────────────────
DEBUG=false

# ── AWS Textract ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── GCP Document AI ───────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp_sa_key.json
GCP_PROJECT_ID=
GCP_LOCATION=us
GCP_PROCESSOR_ID=

# ── Azure Document Intelligence ───────────────────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── LLM Providers (via LiteLLM) ───────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_STUDIO_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# ── Cache / DB ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SQLITE_PATH=data/omniextract.db

# ── Worker (Local Models) ─────────────────────────────────────────────────────
WORKER_BASE_URL=http://worker:8001
LOCAL_WORKER_BACKEND=heuristic
LOCAL_WORKER_DEVICE=auto
LOCAL_WORKER_MODEL_ID=HuggingFaceTB/SmolVLM2-2.2B-Instruct
LOCAL_WORKER_MAX_NEW_TOKENS=256
